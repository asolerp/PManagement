rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: usuario autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: es el propio usuario o tiene claim admin (para dashboard)
    function isOwnerOrAdmin(userId) {
      return request.auth.uid == userId || request.auth.token.admin == true;
    }

    // ——— users ———
    // Single-tenant: cualquier autenticado puede leer y escribir usuarios.
    // El dashboard (solo admins) gestiona todos los perfiles.
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // ——— houses ———
    match /houses/{houseId} {
      allow read, write: if isSignedIn();
    }

    // ——— incidences ———
    match /incidences/{incidenceId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ——— checklists ———
    match /checklists/{checklistId} {
      allow read, write: if isSignedIn();
      match /checks/{checkId} {
        allow read, write: if isSignedIn();
      }
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ——— jobs ———
    match /jobs/{jobId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ——— entrances ———
    match /entrances/{entranceId} {
      allow read, write: if isSignedIn();
    }

    // ——— quadrants ———
    match /quadrants/{quadrantId} {
      allow read, write: if isSignedIn();
      match /jobs/{jobId} {
        allow read, write: if isSignedIn();
      }
    }

    // ——— tasks (catálogo de tareas para jobs) ———
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    // ——— checks (plantilla global de checks) ———
    match /checks/{checkId} {
      allow read, write: if isSignedIn();
    }

    // ——— recycleBin (papelera; usado por admin dashboard) ———
    match /recycleBin/{docId} {
      allow read, write: if isSignedIn();
    }

    // ——— workShifts (acceso desde dashboard vía API; por si hubiera acceso directo) ———
    match /workShifts/{shiftId} {
      allow read, write: if isSignedIn();
    }

    // ——— inspectionReports (reportes del bot de Telegram) ———
    match /inspectionReports/{reportId} {
      allow read, write: if isSignedIn();
    }

    // ——— agentSessions (sesiones del agente IA) ———
    match /agentSessions/{sessionId} {
      allow read, write: if isSignedIn();
    }

    // ——— auditLog (registro de auditoría) ———
    match /auditLog/{logId} {
      allow read: if isSignedIn();
    }

    // ——— settings ———
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }
  }
}
